# ═══════════════════════════════════════════════════════════════
#  Horcrux v5.1 — Environment Variables
#  모든 API 키 양식 정리. 필요한 것만 값을 채우면 됩니다.
# ═══════════════════════════════════════════════════════════════


# ───────────────────────────────────────────
#  CORE: CLI 인증 (환경변수 아님, 참고용)
# ───────────────────────────────────────────
#
#  Claude CLI → claude auth login (브라우저 로그인)
#    - Max ($200/월): Opus 4.6 자동
#    - Pro ($20/월):  Sonnet 4.6 자동
#    - UI/프롬프트에서 모델 전환 가능 (--model claude-sonnet-4-6)
#
#  Codex CLI → codex auth login (브라우저 로그인)
#    - Pro ($200/월): Codex 5.4 (o3-pro) 자동
#    - Plus ($20/월): GPT-4o 자동
#    - 미구독: CLI 실패 → 아래 OPENAI_API_KEY로 자동 전환


# ───────────────────────────────────────────
#  GPT FALLBACK (Codex CLI 미구독 시 자동 전환)
# ───────────────────────────────────────────

# OpenAI API — GPT-4o-mini / GPT-4o (구독 불필요, pay-as-you-go)
# debate 1라운드 Critic 비용: ~$0.01 (GPT-4o-mini 기준)
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ───────────────────────────────────────────
#  AUXILIARY: 오픈소스 API (무료, 보조 Critic + 최종 fallback)
# ───────────────────────────────────────────

# Groq — Llama 3.1 70B (가장 빠름, 무료 tier 넉넉)
# 발급: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Together AI — DeepSeek-V3, Qwen2.5-Coder-32B, Llama 70B
# 발급: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Fireworks AI — Llama 70B, Qwen2.5-Coder
# 발급: https://fireworks.ai/api-keys
FIREWORKS_API_KEY=fw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter — 무료 모델 다수 (Llama, DeepSeek, Qwen 등)
# 발급: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ───────────────────────────────────────────
#  GEMINI (v5에서 optional, v4 하위호환)
# ───────────────────────────────────────────

# Google AI Studio — Gemini 2.5 Flash 등
# 발급: https://aistudio.google.com/apikey
# v5에서는 auxiliary 오픈소스로 대체. 필수 아님.
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ───────────────────────────────────────────
#  ANTHROPIC SDK (선택, CLI 대신 SDK 직접 호출 시)
# ───────────────────────────────────────────

# Anthropic API — Claude SDK 직접 호출
# 발급: https://console.anthropic.com/settings/keys
# CLI 사용 시 불필요. SDK fallback / 테스트용.
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ═══════════════════════════════════════════════════════════════
#  추천 조합 (상황별)
# ═══════════════════════════════════════════════════════════════
#
#  [풀스펙] Claude Max + GPT Pro + 오픈소스 3개
#    → Opus 4.6 ↔ Codex 5.4 debate + Groq/Together/OpenRouter aux
#    → 비용: ~$400/월, 최고 품질
#
#  [균형]   Claude Pro + GPT Plus + OPENAI_API_KEY + GROQ_API_KEY
#    → Sonnet 4.6 ↔ GPT-4o debate + GPT-4o-mini/Llama aux
#    → 비용: ~$40/월 + API 소액
#
#  [최저]   Claude Pro + OPENAI_API_KEY + GROQ_API_KEY
#    → Sonnet 4.6 generate + GPT-4o-mini critic + Llama aux
#    → 비용: ~$20/월 + 거의 $0
#
# ═══════════════════════════════════════════════════════════════
