  "phase_1_5": {
    "purpose": "Phase 1 안정화 후 context/tokens 문제를 점진적으로 해결",
    "prerequisite": "Phase 1 (routing + timeout + revision cap)이 안정적으로 운영 중일 것",
    "items": [
      {
        "name": "compact_state_memory",
        "description": "전체 대화/출력을 매번 다시 넣지 않고 작업 상태를 압축해서 유지",
        "mode_specific_policy": {
          "fast": "working_memory only or skip entirely",
          "standard": "working_memory + result_summary_memory",
          "full_horcrux": "working_memory + decision_memory + result_summary_memory (3-layer 전부)"
        },
        "memory_layers": {
          "working_memory": {
            "schema": {"task": "string", "current_goal": "string", "blocking_issues": ["string"], "preserve": ["string"], "must_not_change": ["string"]}
          },
          "decision_memory": {
            "schema": {"accepted_decisions": [{"topic": "string", "choice": "string", "reason": "string"}], "rejected_alternatives": [{"topic": "string", "alternative": "string", "reason_not_selected": "string"}], "open_questions": ["string"]}
          },
          "result_summary_memory": {
            "schema": {"content_summary": "string", "structure_summary": "string", "key_messages": ["string"], "resolved_items": ["string"], "remaining_blockers": ["string"]}
          }
        },
        "required_functions": [
          "update_working_memory()",
          "update_decision_memory()",
          "update_result_summary_memory()"
        ],
        "hard_rule": "다음 단계 prompt에는 full previous output 대신 compact memory만 기본 입력으로 사용"
      },
      {
        "name": "create_round_checkpoint",
        "description": "매 라운드 후 요약 체크포인트를 생성하여 컨텍스트 잘림 방지",
        "output_schema": {
          "round": 1,
          "current_conclusion": "string",
          "what_changed": ["string"],
          "remaining_blockers": ["string"],
          "preserve": ["string"],
          "must_not_change": ["string"]
        },
        "usage_rule": "이전 라운드 전체 출력 대신 checkpoint summary를 다음 라운드의 기본 입력으로 사용"
      },
      {
        "name": "delta_based_prompting",
        "description": "매 단계마다 전체 이슈를 반복하지 않고 새로 바뀐 것과 핵심 blocker만 전달",
        "schema": {
          "current_state_summary": "string",
          "new_blockers": ["string"],
          "resolved_items": ["string"],
          "preserve": ["string"],
          "next_action": "string"
        },
        "hard_rules": [
          "previous full output 재삽입 금지",
          "critic 전체 목록 재삽입 금지",
          "이미 accepted된 내용은 짧은 preserve 항목으로만 전달",
          "blocking issue와 delta만 중심으로 전달"
        ]
      }
    ]
  },

  "phase_2": {
    "purpose": "writer/patch/artifact 안정화 + aux 고도화",
    "prerequisite": "Phase 1.5 (compact memory + checkpoint + delta prompting)이 안정적일 것",
    "items": [
      {
        "name": "single_writer_rule_enforcement",
        "description": "여러 CLI 에이전트가 동시에 파일을 write하지 못하게 하여 충돌 방지",
        "roles": {
          "generators": ["read", "propose_patch"],
          "critics": ["read", "comment"],
          "director": ["read", "select", "merge"],
          "writer": ["read", "write", "run_tests"]
        }
      },
      {
        "name": "patch_format_standardization",
        "description": "propose_patch 포맷을 JSON patch로 통일하여 director merge 가능하게 함",
        "preferred_format": "json_patch_with_reason",
        "schema": {
          "file": "path/to/file",
          "hunks": [
            {
              "start_line": 10,
              "end_line": 15,
              "original": "old code",
              "proposed": "new code",
              "reason": "why this change"
            }
          ]
        }
      },
      {
        "name": "conditional_aux_usage_refinement",
        "description": "Aux critic을 항상 돌리지 않고 불확실하거나 중요할 때만 활성화",
        "activation_conditions": [
          "core critic disagreement 발생",
          "overall score가 threshold 근처에서 애매함",
          "critical issue unresolved",
          "task mode == full_horcrux",
          "high-risk task"
        ],
        "skip_conditions": [
          "fast mode",
          "low-risk change",
          "clear convergence from core critics only"
        ],
        "required_function": {
          "name": "should_run_aux_critics",
          "input": {
            "mode": "fast|standard|full_horcrux",
            "core_scores": {"model_a": 0.0, "model_b": 0.0},
            "critical_issue_count": 0,
            "risk_level": "low|medium|high"
          },
          "output": {"run_aux": false, "reason": "string"}
        }
      },
      {
        "name": "artifact_spec_optimization",
        "description": "PPT/PDF 같은 artifact는 멀티모델이 파일 자체를 직접 수정하지 않고 spec 기반 렌더링으로 간소화",
        "rules": [
          "artifact 단계는 final content package를 입력으로 받음",
          "artifact_profile은 내용 재해석 금지",
          "PPT/PDF는 artifact-ready spec을 만든 후 최종 renderer가 생성",
          "artifact critic은 정보량/흐름/누락만 점검"
        ]
      },
      {
        "name": "advanced_fallback_chain",
        "description": "Phase 1의 minimum default fallback action 위에 더 정교한 chain을 구축",
        "fallback_chain_per_stage": {
          "generator": ["retry_once", "use_partial_results", "fallback_model"],
          "synth": ["use_best_candidate", "retry_with_shorter_prompt"],
          "core_critic": ["retry_once", "fallback_critic_model", "flag_unresolved"],
          "aux_critic": ["skip_immediately"],
          "revision": ["keep_current_version", "flag_blockers"]
        }
      }
    ]
  },

  "phase_3": {
    "purpose": "운영 데이터 기반 튜닝 + 자동 최적화",
    "prerequisite": "Phase 2 완료 + latency jsonl 로그 데이터가 충분히 축적되었을 것",
    "items": [
      {
        "name": "timeout_auto_tuning",
        "description": "jsonl latency 로그에서 P50/P90/P99를 산출하여 timeout 값을 자동 조정",
        "approach": "1.5x~2x of P90 → 점진적으로 타이트하게",
        "data_source": "./logs/horcrux_stage_latency.jsonl"
      },
      {
        "name": "routing_heuristic_refinement",
        "description": "mode_usage_count, 실제 결과 품질, latency 데이터로 heuristic 키워드와 threshold 미세 조정",
        "metrics_needed": ["mode_usage_count", "mode_vs_quality_score", "mode_vs_latency"]
      },
      {
        "name": "llm_fallback_for_classification",
        "description": "Phase 1에서 safe_default=standard로 처리하던 confidence < 0.6 케이스를 lightweight LLM 호출로 대체",
        "approach": "core pair 중 하나에 10-token 분류 prompt를 보내서 fast/standard/full_horcrux 중 하나 반환",
        "enable_condition": "config.json의 adaptive_horcrux.routing.enable_llm_fallback = true"
      },
      {
        "name": "critic_reliability_weighting",
        "description": "critic별 정확도/일관성 이력을 추적하여 점수 가중치를 동적으로 조정",
        "approach": "critic의 score vs 최종 품질 상관관계를 학습하여 reliable critic에 더 높은 weight 부여"
      },
      {
        "name": "mode_quality_latency_analytics",
        "description": "모드별 품질/속도 트레이드오프를 대시보드로 시각화",
        "metrics": [
          "per_mode_avg_latency",
          "per_mode_avg_score",
          "per_mode_convergence_rate",
          "per_mode_revision_count",
          "per_mode_timeout_rate"
        ]
      }
    ]
  },

